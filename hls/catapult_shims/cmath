#ifndef TVM_WORK_LLM_ACCELERATOR_CATAPULT_SHIMS_CMATH
#define TVM_WORK_LLM_ACCELERATOR_CATAPULT_SHIMS_CMATH

#ifndef FP_NAN
#define FP_NAN 0
#endif

#ifndef FP_INFINITE
#define FP_INFINITE 1
#endif

#ifndef FP_ZERO
#define FP_ZERO 2
#endif

#ifndef FP_SUBNORMAL
#define FP_SUBNORMAL 3
#endif

#ifndef FP_NORMAL
#define FP_NORMAL 4
#endif

extern "C" {
double sqrt(double value);
float sqrtf(float value);
double ceil(double value);
float ceilf(float value);
double floor(double value);
float floorf(float value);
float truncf(float value);
float roundf(float value);
float fmaf(float x, float y, float z);
}

namespace std {

inline int fpclassify(float value) {
  union {
    float f;
    unsigned int u;
  } bits = {value};
  unsigned int exponent = (bits.u >> 23) & 0xffU;
  unsigned int mantissa = bits.u & 0x7fffffU;
  if (exponent == 0xffU) {
    return mantissa ? FP_NAN : FP_INFINITE;
  }
  if (exponent == 0U) {
    return mantissa ? FP_SUBNORMAL : FP_ZERO;
  }
  return FP_NORMAL;
}

inline int fpclassify(double value) {
  union {
    double d;
    unsigned long long u;
  } bits = {value};
  unsigned long long exponent = (bits.u >> 52) & 0x7ffULL;
  unsigned long long mantissa = bits.u & 0xfffffffffffffULL;
  if (exponent == 0x7ffULL) {
    return mantissa ? FP_NAN : FP_INFINITE;
  }
  if (exponent == 0ULL) {
    return mantissa ? FP_SUBNORMAL : FP_ZERO;
  }
  return FP_NORMAL;
}

inline bool signbit(float value) {
  union {
    float f;
    unsigned int u;
  } bits = {value};
  return (bits.u >> 31) != 0;
}

inline bool signbit(double value) {
  union {
    double d;
    unsigned long long u;
  } bits = {value};
  return (bits.u >> 63) != 0;
}

inline bool isnan(float value) {
  return value != value;
}

inline bool isnan(double value) {
  return value != value;
}

inline bool isfinite(float value) {
  int cls = fpclassify(value);
  return cls == FP_NORMAL || cls == FP_SUBNORMAL || cls == FP_ZERO;
}

inline bool isfinite(double value) {
  int cls = fpclassify(value);
  return cls == FP_NORMAL || cls == FP_SUBNORMAL || cls == FP_ZERO;
}

inline bool isnormal(float value) {
  return fpclassify(value) == FP_NORMAL;
}

inline bool isnormal(double value) {
  return fpclassify(value) == FP_NORMAL;
}

inline bool isinf(float value) {
  return fpclassify(value) == FP_INFINITE;
}

inline bool isinf(double value) {
  return fpclassify(value) == FP_INFINITE;
}

inline int __builtin_fpclassify(int nan_value, int inf_value, int normal_value, int subnormal_value, int zero_value, float value) {
  switch (fpclassify(value)) {
    case FP_NAN: return nan_value;
    case FP_INFINITE: return inf_value;
    case FP_NORMAL: return normal_value;
    case FP_SUBNORMAL: return subnormal_value;
    default: return zero_value;
  }
}

inline int __builtin_fpclassify(int nan_value, int inf_value, int normal_value, int subnormal_value, int zero_value, double value) {
  switch (fpclassify(value)) {
    case FP_NAN: return nan_value;
    case FP_INFINITE: return inf_value;
    case FP_NORMAL: return normal_value;
    case FP_SUBNORMAL: return subnormal_value;
    default: return zero_value;
  }
}

inline int __builtin_isfinite(float value) {
  return isfinite(value) ? 1 : 0;
}

inline int __builtin_isfinite(double value) {
  return isfinite(value) ? 1 : 0;
}

inline int __builtin_isnormal(float value) {
  return isnormal(value) ? 1 : 0;
}

inline int __builtin_isnormal(double value) {
  return isnormal(value) ? 1 : 0;
}

inline float ceil(float value) {
  return ::ceilf(value);
}

inline double ceil(double value) {
  return ::ceil(value);
}

inline float floor(float value) {
  return ::floorf(value);
}

inline double floor(double value) {
  return ::floor(value);
}

inline float sqrt(float value) {
  return ::sqrtf(value);
}

inline double sqrt(double value) {
  return ::sqrt(value);
}

}  // namespace std

#endif