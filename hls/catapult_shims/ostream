#ifndef TVM_WORK_LLM_ACCELERATOR_CATAPULT_SHIMS_OSTREAM
#define TVM_WORK_LLM_ACCELERATOR_CATAPULT_SHIMS_OSTREAM

namespace std {

struct ios_base {
  typedef unsigned long fmtflags;
  static const fmtflags hex = 1UL << 0;
  static const fmtflags oct = 1UL << 1;
};

struct ios : ios_base {};

template <typename CharT>
class basic_ostream {
public:
  typedef ios_base::fmtflags fmtflags;

  fmtflags flags() const { return 0; }

  template <typename T>
  basic_ostream &operator<<(const T &) { return *this; }

  basic_ostream &operator<<(basic_ostream &(*manip)(basic_ostream &)) {
    return manip(*this);
  }
};

typedef basic_ostream<char> ostream;

extern ostream cout;
extern ostream cerr;

inline ostream &endl(ostream &os) {
  return os;
}

}  // namespace std

#endif